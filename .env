# ─── Supabase (PostgreSQL) ─────────────────────────────────────────────────
#
# Obtén estos valores en: https://supabase.com/dashboard/project/TU-PROYECTO/settings/database
#
# DATABASE_URL → "Connection string" → modo "Transaction" (puerto 6543, con pooler)
# DIRECT_URL   → "Connection string" → modo "Session" (puerto 5432, directo)
#
# Reemplaza [PASSWORD] con tu contraseña de Supabase y [PROJECT-REF] con tu ID de proyecto.

DATABASE_URL="postgresql://postgres.PROJECT-REF:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT-REF:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
