generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // URL del pooler (puerto 6543) — para runtime en Vercel
  directUrl = env("DIRECT_URL")         // URL directa (puerto 5432) — para prisma migrate/db push
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  icon        String?  // Emoji o nombre de icono
  unitCost    Float
  margin      Float    // Ejemplo: 0.3 para 30%
  salePrice   Float
  stock       Int      @default(0) // Control de inventario
  sales       Sale[]
}

model Sale {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  quantity      Int
  orderProfit   Float
  
  // Relación con el producto
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
}
